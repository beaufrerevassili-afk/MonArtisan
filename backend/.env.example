# Serveur
NODE_ENV=development
PORT=5000

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artisans_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase (notifications temps réel)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# SendGrid (emails)
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@artisans-app.fr
FROM_NAME=Artisans App

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+33...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# AWS S3 (stockage documents)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=artisans-documents

# Chiffrement AES-256
ENCRYPTION_KEY=your_32_char_encryption_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox

# DocuSign / YouSign
YOUSIGN_API_KEY=your_yousign_api_key
YOUSIGN_BASE_URL=https://api.yousign.app/v3
